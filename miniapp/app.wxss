page {
  background: #f4efe6;
  color: #2e261c;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Noto Serif SC", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 82% 12%, rgba(163, 188, 231, 0.42), transparent 22%),
    radial-gradient(circle at 65% 18%, rgba(241, 206, 137, 0.2), transparent 18%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(248, 242, 232, 0.96));
}

.panel {
  background: rgba(255, 251, 245, 0.94);
  border: 1rpx solid rgba(188, 170, 137, 0.24);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(112, 91, 58, 0.08);
  padding: 28rpx;
  box-sizing: border-box;
}

.section-stack { display: flex; flex-direction: column; gap: 20rpx; }
.section-eyebrow { font-size: 24rpx; color: #8c785d; letter-spacing: 2rpx; }
.section-title { font-size: 54rpx; line-height: 1.04; font-family: "Times New Roman", "Noto Serif SC", serif; font-weight: 700; color: #21170f; }
.section-copy, .card-copy, .factor-value { font-size: 28rpx; line-height: 1.7; color: #4c4031; }
.chip-row { display: flex; flex-wrap: wrap; gap: 16rpx; }
.chip { padding: 14rpx 24rpx; border-radius: 999rpx; border: 1rpx solid rgba(185, 164, 128, 0.34); background: rgba(252, 247, 238, 0.94); color: #7b6648; font-size: 28rpx; }
.chip.is-active { color: #ffffff; border-color: transparent; }
.subtle-pill { display: inline-flex; align-items: center; justify-content: center; padding: 10rpx 20rpx; border-radius: 999rpx; background: rgba(244, 248, 255, 0.9); color: #4c74b6; font-size: 24rpx; }
.metric-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16rpx; }
.metric-card, .factor-card, .list-item { padding: 22rpx; border-radius: 24rpx; background: rgba(255, 252, 246, 0.95); border: 1rpx solid rgba(188, 170, 137, 0.2); }
.metric-label, .list-meta, .factor-label, .history-tag { font-size: 24rpx; color: #8b7657; }
.metric-value { margin-top: 10rpx; font-size: 44rpx; font-weight: 700; color: #23180e; }
.card-title, .list-title, .history-title { font-size: 34rpx; font-weight: 700; color: #20160f; }
.list-stack { display: flex; flex-direction: column; gap: 16rpx; }
.button-primary { display: inline-flex; align-items: center; justify-content: center; padding: 20rpx 26rpx; border-radius: 999rpx; font-size: 28rpx; font-weight: 600; color: #ffffff; border: none; }
.button-ghost { display: inline-flex; align-items: center; justify-content: center; padding: 18rpx 24rpx; border-radius: 999rpx; font-size: 28rpx; color: #6f5b42; background: rgba(255, 252, 247, 0.94); border: 1rpx solid rgba(188, 170, 137, 0.24); }
.empty-state { padding: 56rpx 28rpx; text-align: center; color: #8d795c; font-size: 28rpx; }
.portrait-card { display: flex; gap: 24rpx; align-items: stretch; }
.portrait-frame { width: 180rpx; min-width: 180rpx; height: 240rpx; overflow: hidden; border-radius: 28rpx; background: rgba(227, 216, 194, 0.5); border: 1rpx solid rgba(188, 170, 137, 0.22); }
.portrait-frame image { width: 100%; height: 100%; }
.portrait-fallback { display: flex; align-items: center; justify-content: center; font-size: 72rpx; color: #8e7856; }
.hero-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.hero-chip { display: flex; align-items: center; gap: 12rpx; padding: 12rpx 18rpx; border-radius: 999rpx; background: rgba(255, 252, 247, 0.94); border: 1rpx solid rgba(188, 170, 137, 0.22); font-size: 24rpx; color: #4a3f31; }
.hero-chip image { width: 40rpx; height: 40rpx; border-radius: 50%; }
.split-head, .history-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 16rpx; }
.history-item { padding: 20rpx 0; border-bottom: 1rpx solid rgba(188, 170, 137, 0.16); }
.history-item:last-child { border-bottom: none; }
